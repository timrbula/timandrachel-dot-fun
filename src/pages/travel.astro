---
import BaseLayout from "../components/astro/BaseLayout.astro";
import Marquee from "../components/react/Marquee";
import BlinkingText from "../components/react/BlinkingText";
import RainbowDivider from "../components/react/RainbowDivider";
import GeoButton from "../components/react/GeoButton";
---

<BaseLayout
  title="Travel & Accommodations - Rachel & Tim ✈️"
  description="Everything you need to know about getting to Brooklyn and where to stay for our wedding!"
>
  <!-- Top Marquee -->
  <Marquee client:load speed={15}>
    ✈️ Travel Guide ✈️ Hotels ✈️ Getting Around NYC ✈️ Brooklyn Tips ✈️
  </Marquee>

  <div class="container">
    <!-- Page Header -->
    <section class="page-header text-center">
      <h1 class="text-3d">
        <BlinkingText client:load speed="slow">✈️</BlinkingText>
        Travel & Accommodations
        <BlinkingText client:load speed="slow">🗽</BlinkingText>
      </h1>
    </section>

    <RainbowDivider client:load variant="animated" />

    <!-- Hotels Section -->
    <section class="hotels-section">
      <h2 class="text-center text-3d">
        <BlinkingText client:load>🏨</BlinkingText>
        Where to Stay
        <BlinkingText client:load>🏨</BlinkingText>
      </h2>

      <div class="hotel-note geo-box text-center">
        <p>
          <BlinkingText client:load>💡</BlinkingText>
          <strong>Pro Tip:</strong> We recommend staying in one of these three neighborhoods for easy access to our events. Book early — October in NYC fills up fast! 🍂
        </p>
      </div>

      <div class="neighborhoods-grid">
        <!-- Midtown -->
        <div class="hotel-card geo-box-neon">
          <div>
          <h3 class="text-neon">Midtown Manhattan</h3>
          <div class="hotel-details">
            <ul>
              <li>✅ Subway access to all of our events in Brooklyn</li>
              <li>✅ Widest selection of hotels</li>
              <li>✅ Central Park and many attractions</li>
              <li>❌ Can be a bit overwhelming</li>
            </ul>
          </div>
          </div>
          <GeoButton
            client:load
            variant="primary"
            href="https://www.google.com/maps/search/hotels+midtown+manhattan"
          >
            🔍 Search Hotels
          </GeoButton>
        </div>

        <!-- Downtown Brooklyn -->
        <div class="hotel-card geo-box-neon">
          <div>
          <h3 class="text-neon">Downtown Brooklyn</h3>
          <div class="hotel-details">
            <ul>
              <li>✅ Easiest access to all of the events</li>
              <li>✅ More affordable than Manhattan</li>
              <li>❌ Not the cutest part of the city, imo</li>
            </ul>
          </div>
          </div>
          <GeoButton
            client:load
            variant="primary"
            href="https://www.google.com/maps/search/hotels+downtown+brooklyn"
          >
            🔍 Search Hotels
          </GeoButton>
        </div>

        <!-- Lower Manhattan -->
        <div class="hotel-card geo-box-neon">
        <div>
          <h3 class="text-neon-pink">Lower Manhattan</h3>
          <div class="hotel-details">
            <ul>
              <li>✅ Multiple subway lines to Brooklyn</li>
              <li>✅ More fun place to stay, imo</li>
              <li>❌ Less hotel options</li>
            </ul>
          </div>
          </div>
          <GeoButton
            client:load
            variant="primary"
            href="https://www.google.com/maps/search/hotels+lower+manhattan"
          >
            🔍 Search Hotels
          </GeoButton>
        </div>
      </div>

