<style>
  /* Page Header */
  .page-header {
    padding: 2rem 0;
  }

  .page-header h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.3rem;
    max-width: 800px;
    margin: 0 auto;
  }

  /* Hotels Section */
  .hotels-section {
    margin: 3rem 0;
  }

  .hotels-grid,
  .neighborhoods-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 2rem auto;
  }

  .hotel-card {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hotel-card h3 {
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }

  .hotel-location,
  .hotel-distance {
    font-size: 1.1rem;
    margin-bottom: 0.5rem;
  }

  .hotel-details {
    margin: 1.5rem 0;
  }

  .hotel-details ul {
    margin: 0.5rem 0 1rem 1.5rem;
  }

  .hotel-details li {
    margin-bottom: 0.3rem;
  }

  .hotel-note {
    max-width: 700px;
    margin: 2rem auto;
    padding: 1.5rem;
  }

  /* Airports Section */
  .airports-section {
    margin: 3rem 0;
  }

  .airports-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 2rem auto;
  }

  .airport-card {
    padding: 2rem;
  }

  .airport-card h3 {
    font-size: 1.6rem;
    margin-bottom: 0.5rem;
  }

  .airport-distance {
    color: var(--color-cyan);
    margin-bottom: 1rem;
  }

  .transport-options ul {
    margin: 0.5rem 0 1rem 1.5rem;
  }

  .transport-options li {
    margin-bottom: 0.3rem;
  }

  /* Subway Section */
  .subway-section {
    margin: 3rem 0;
  }

  .subway-content {
    max-width: 900px;
    margin: 2rem auto;
    padding: 2.5rem;
  }

  .subway-info h3 {
    font-size: 1.6rem;
    margin: 1.5rem 0 1rem 0;
  }

  .subway-info h3:first-child {
    margin-top: 0;
  }

  .subway-info ul {
    margin: 0.5rem 0 1rem 1.5rem;
  }

  .subway-info li {
    margin-bottom: 0.5rem;
  }

  /* Neighborhood Section */
  .neighborhood-section {
    margin: 3rem 0;
  }

  .neighborhood-intro {
    max-width: 800px;
    margin: 2rem auto;
    padding: 2rem;
  }

  .neighborhood-description {
    font-size: 1.2rem;
    line-height: 1.8;
  }

  .neighborhood-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 2rem auto;
  }

  .neighborhood-card {
    padding: 2rem;
  }

  .neighborhood-card h3 {
    font-size: 1.6rem;
    margin-bottom: 1rem;
  }

  .neighborhood-card ul {
    margin: 0.5rem 0 0 1.5rem;
  }

  .neighborhood-card li {
    margin-bottom: 0.8rem;
    line-height: 1.5;
  }

  /* Tips Section */
  .tips-section {
    margin: 3rem 0;
  }

  .tips-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 1.5rem;
    max-width: 1200px;
    margin: 2rem auto;
  }

  .tip-card {
    padding: 1.5rem;
    text-align: center;
  }

  .tip-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
  }

  .tip-card p {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  /* Attractions Section */
  .attractions-section {
    margin: 3rem 0;
  }

  .attractions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1200px;
    margin: 2rem auto;
  }

  .attraction-card {
    padding: 2rem;
  }

  .attraction-card h3 {
    font-size: 1.6rem;
    margin-bottom: 1rem;
  }

  .attraction-card ul {
    margin: 0.5rem 0 0 1.5rem;
  }

  .attraction-card li {
    margin-bottom: 0.5rem;
  }

  .attractions-note {
    max-width: 700px;
    margin: 2rem auto;
    padding: 1.5rem;
  }

  /* CTA Section */
  .cta-section {
    max-width: 700px;
    margin: 3rem auto;
    padding: 3rem 2rem;
  }

  .cta-text {
    font-size: 1.2rem;
    margin: 1.5rem 0;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2.5rem;
    }

    .subtitle {
      font-size: 1.1rem;
    }

    .hotels-grid,
    .airports-grid,
    .neighborhood-grid,
    .attractions-grid {
      grid-template-columns: 1fr;
    }

    .tips-grid {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    }

    .cta-buttons {
      flex-direction: column;
    }
  }
</style>
