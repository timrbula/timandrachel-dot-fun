const WEDDING_START = "2026-10-09T18:00:00-04:00"; // 6:00 PM EDT
const WEDDING_END = "2026-10-09T23:00:00-04:00"; // 11:00 PM EDT
const WEDDING_DESCRIPTION =
  "Join us for our wedding celebration! Welcome drinks start at 6:00 PM followed dinner, dessert and dancing. We can't wait to celebrate with you!";

const PICNIC_START = "2026-10-10T11:00:00-04:00"; // 11:00 AM EDT
const PICNIC_END = "2026-10-10T13:00:00-04:00"; // 1:00 PM EDT
