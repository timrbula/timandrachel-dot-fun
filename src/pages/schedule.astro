<style>
  /* Page Header */
  .page-header {
    padding: 2rem 0;
  }

  .page-header h1 {
    font-size: 3.5rem;
    margin-bottom: 1rem;
  }

  .subtitle {
    font-size: 1.3rem;
    max-width: 700px;
    margin: 0 auto;
  }

  /* Date Section */
  .date-section {
    margin: 3rem 0;
  }

  .date-box {
    max-width: 600px;
    margin: 0 auto;
    padding: 2.5rem;
  }

  .date-box h2 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .ceremony-time {
    font-size: 2.5rem;
    font-weight: bold;
    margin: 1rem 0;
  }

  .venue-name {
    font-size: 1.8rem;
    font-weight: bold;
    margin: 1rem 0;
  }

  .venue-address {
    font-size: 1.2rem;
    color: var(--color-cyan);
  }

  /* Timeline */
  .timeline-section {
    margin: 3rem 0;
  }

  .timeline {
    max-width: 800px;
    margin: 2rem auto;
  }

  .timeline-item {
    display: flex;
    gap: 2rem;
    padding: 2rem;
    margin-bottom: 1rem;
    align-items: flex-start;
  }

  .timeline-icon {
    font-size: 3rem;
    flex-shrink: 0;
  }

  .timeline-content h3 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }

  .timeline-content p {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }

  .timeline-arrow {
    margin: 1rem 0;
  }

  .arrow-down {
    font-size: 2rem;
    animation: bounce 2s infinite;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(10px);
    }
  }

  /* Venue Section */
  .venue-section {
    margin: 3rem 0;
  }

  .venue-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 2rem;
    max-width: 1000px;
    margin: 2rem auto;
  }

  .venue-info,
  .subway-info {
    padding: 2rem;
  }

  .venue-info h3,
  .subway-info h3 {
    font-size: 1.8rem;
    margin-bottom: 1rem;
  }

  .venue-description {
    margin: 1.5rem 0;
    line-height: 1.6;
  }

  .subway-routes {
    margin: 1.5rem 0;
  }

  .subway-routes ul {
    margin: 0.5rem 0 1rem 1.5rem;
  }

  .subway-routes li {
    margin-bottom: 0.3rem;
  }

  .subway-tip {
    margin-top: 1.5rem;
    padding: 1rem;
    background: rgba(255, 255, 0, 0.1);
    border: 2px dashed var(--color-yellow);
    border-radius: 8px;
  }

  /* Map Section */
  .map-section {
    margin: 3rem 0;
  }

  .map-container {
    max-width: 900px;
    margin: 2rem auto;
    padding: 1rem;
  }

  .map-container iframe {
    border-radius: 8px;
  }

  /* Additional Info */
  .additional-info {
    margin: 3rem 0;
  }

  .info-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    max-width: 1100px;
    margin: 0 auto;
  }

  .info-card {
    padding: 2rem;
  }

  .info-card h3 {
    font-size: 1.6rem;
    margin-bottom: 1rem;
    color: var(--color-cyan);
  }

  .info-card ul {
    margin: 0.5rem 0 1rem 1.5rem;
  }

  .info-card li {
    margin-bottom: 0.3rem;
  }

  .parking-tip,
  .weather-note,
  .accessibility-note {
    margin-top: 1rem;
    font-size: 0.95rem;
  }

  /* CTA Section */
  .cta-section {
    max-width: 700px;
    margin: 3rem auto;
    padding: 3rem 2rem;
  }

  .cta-text {
    font-size: 1.2rem;
    margin: 1.5rem 0;
  }

  .cta-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .page-header h1 {
      font-size: 2.5rem;
    }

    .subtitle {
      font-size: 1.1rem;
    }

    .ceremony-time {
      font-size: 2rem;
    }

    .venue-name {
      font-size: 1.5rem;
    }

    .timeline-item {
      flex-direction: column;
      gap: 1rem;
      padding: 1.5rem;
    }

    .timeline-icon {
      font-size: 2.5rem;
    }

    .venue-grid {
      grid-template-columns: 1fr;
    }

    .info-grid {
      grid-template-columns: 1fr;
    }

    .cta-links {
      flex-direction: column;
    }
  }
</style>
